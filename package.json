{
  "name": "sync-pipeline",
  "version": "0.1.0",
  "description": "Multi-source sync pipeline: HubSpot + Google Calendar + Notion → normalized Postgres",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.1",
    "@hubspot/api-client": "^13.5.0",
    "@notionhq/client": "^5.22.0",
    "cockatiel": "^4.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.0",
    "fastify-plugin": "^6.0.0",
    "googleapis": "^173.0.0",
    "pg": "^8.13.1",
    "pg-boss": "^12.19.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
