# --- Database (Neon Postgres) ---
# Pooled connection string (port 6543, pgbouncer) — used for runtime queries
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# Direct connection string (port 5432) — used only for migrations
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require

# --- Service ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Management endpoint auth (Phase 2+) ---
API_SECRET=change-me-min-32-chars-long-random-token

# --- HubSpot (Phase 3) ---
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_CLIENT_SECRET=

# --- Google Calendar (Phase 4) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
# Static shared secret echoed by Google as X-Goog-Channel-Token; set when
# creating a push channel. Required only if you register a watch channel.
GOOGLE_WEBHOOK_TOKEN=

# --- Notion (Phase 5) ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Cron runner (Phase 6) ---
WEB_SERVICE_URL=http://localhost:3000
